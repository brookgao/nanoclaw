# Feishu (国内飞书) — set both to enable the Feishu channel
FEISHU_APP_ID=
FEISHU_APP_SECRET=
# Optional: "feishu" (default, 国内) or "lark" (海外)
FEISHU_DOMAIN=feishu

# GitHub Personal Access Token — granted to EVERY container so any group can
# `git push` and `gh pr create` directly. Use a fine-grained token scoped to
# the repos you want the agent to touch (contents:write + pull-requests:write).
# Leave blank to keep agents read-only on GitHub.
GH_TOKEN=
